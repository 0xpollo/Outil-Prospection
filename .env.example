# Copier vers .env et renseigner les valeurs.
# Le fichier .env est ignoré par git (voir .gitignore).

# Service VPS de vérification SMTP (RCPT TO réel sur le serveur MX)
# Déployé sur le VPS Contabo, port 8000.
VERIFIER_URL=http://79.143.189.160:8000
VERIFIER_KEY=

# Perplexity Sonar : recherche du site web officiel + email dirigeant.
# Pricing : ~$0.005 par recherche d'entreprise (low context, sonar).
# Laisser vide pour désactiver l'étape Perplexity.
PERPLEXITY_API_KEY=
